# Example environment configuration for local development.
# Copy this file to .env and replace the placeholder values.
POSTGRES_USER=workshpere
POSTGRES_PASSWORD=change_me
POSTGRES_DB=workshpere_DB
DATABASE_URL=postgresql://workshpere:change_me@db:5432/workshpere_DB
# Generate locally with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-your-generated-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
